# Secrets for first-boot provisioning. Copy to `firstrun.env` and fill in.
# This file is gitignored — never commit real credentials.
# Used by firstrun.sh (and copied to the SD card's boot partition).

# Wi-Fi (leave blank to use Ethernet or set Wi-Fi via Raspberry Pi Imager instead)
WIFI_SSID=""
WIFI_PSK=""
WIFI_COUNTRY="US"

# Optional: set/replace the login password for the user in pi-config.json.
# Leave blank to keep whatever Raspberry Pi Imager set.
USER_PASS=""
