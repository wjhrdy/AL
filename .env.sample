# Audio input device number (run `just select-device` to find your device number)
# AL_DEVICE=1

# GitHub personal access token for fetching remote config (optional).
# Avoids the 60 req/hr unauthenticated GitHub API rate limit (raises it to 5000/hr).
# A fine-grained token with read-only "Gists" access (or a classic token with the
# "gist" scope) is sufficient. Create one at https://github.com/settings/tokens
# GITHUB_TOKEN=ghp_your_token_here

# Port for the local "refresh config" web server (default 8080). Open
# http://<pi-ip>:<port> on a phone/tablet on the same network to force a refresh.
# AL_WEB_PORT=8080
